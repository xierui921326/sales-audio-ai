{
  "productName": "Sales Audio AI",
  "version": "1.0.0",
  "identifier": "com.xier.sales-audio-ai",
  "build": {
    "beforeDevCommand": "node ./scripts/dev-or-reuse.mjs",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sales Audio AI",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
