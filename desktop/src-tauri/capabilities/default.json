{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main desktop window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "shell:default",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-audio-read-recursive",
    "core:webview:allow-internal-toggle-devtools"
  ]
}
